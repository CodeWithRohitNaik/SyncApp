@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome to TrustSync</h1>
    <p>Oracle Data Viewer + Manual KPI Entry Application</p>
</div>

<div class="row mt-5">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Binder List</h5>
                <p class="card-text">View and manage flagged engines/APUs with readonly Oracle data and editable KPI fields.</p>
                <a href="/workorder" class="btn btn-primary">Go to Binder List</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">ETL Job Dashboard</h5>
                <p class="card-text">Monitor background jobs for Oracle data synchronization and ETL operations.</p>
                <a href="/hangfire" class="btn btn-primary">View Jobs</a>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="alert alert-info" role="alert">
            <h4 class="alert-heading">Color Coding Guide</h4>
            <hr>
            <p class="mb-0">
                <span class="badge bg-secondary">Gray</span> = Oracle base data (readonly)<br>
                <span class="badge bg-primary">Blue</span> = Oracle data that was updated<br>
                <span class="badge bg-warning text-dark">Yellow</span> = KPI manual entry (editable)
            </p>
        </div>
    </div>
</div>
